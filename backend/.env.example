GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash
CARTESIA_API_KEY=
TAVILY_API_KEY=

# AWS Bedrock (optional — set LLM_PROVIDER=bedrock or auto to use)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# LLM Provider: "gemini", "bedrock", or "auto" (tries Bedrock first, falls back to Gemini)
LLM_PROVIDER=auto
