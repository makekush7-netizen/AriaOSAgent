{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ARIA",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../frontend run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ARIA",
        "url": "index.html",
        "decorations": true,
        "transparent": false,
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "widget",
        "title": "",
        "url": "/widget.html",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "width": 300,
        "height": 400,
        "skipTaskbar": true,
        "x": 20,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
